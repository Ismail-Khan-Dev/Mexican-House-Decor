# Server Configuration
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/mexican-decor-db

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_minimum_32_chars
JWT_EXPIRE=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Email (optional for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# JazzCash Payment Gateway (Pakistan)
JAZZCASH_ENVIRONMENT=sandbox
JAZZCASH_MERCHANT_ID=your_merchant_id
JAZZCASH_PASSWORD=your_password
JAZZCASH_INTEGRITY_SALT=your_integrity_salt
JAZZCASH_RETURN_URL=http://localhost:5000/api/payment/jazzcash/callback
JAZZCASH_MPF1=
JAZZCASH_MPF2=
JAZZCASH_MPF3=
JAZZCASH_MPF4=
JAZZCASH_MPF5=

# Logging
LOG_LEVEL=debug
